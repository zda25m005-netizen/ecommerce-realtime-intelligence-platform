# ============================================================
# E-Commerce Real-Time Intelligence Platform - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- MinIO (S3-compatible Object Storage) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password
MINIO_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minio_admin
AWS_SECRET_ACCESS_KEY=minio_password
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# --- Spark ---
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_MASTER_WEBUI_PORT=8080
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE=sqlite:///mlflow/mlflow.db
MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://mlflow/

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_DB_HOST=airflow-postgres
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# --- BentoML ---
BENTOML_PORT=3001
BENTOML_HOST=0.0.0.0

# --- Ollama ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Data Paths ---
OLIST_DATA_PATH=/opt/data/raw/olist
CLICKSTREAM_DATA=data/raw/retailrocket/events_500k.csv
USER_SUBSET_LIMIT=500000
