{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "Panel 1: Live Recommendation CTR",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "recommendation_ctr_rate",
          "legendFormat": "CTR ({{model_version}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 0.02},
              {"color": "green", "value": 0.05}
            ]
          }
        }
      }
    },
    {
      "title": "Panel 2: Kafka Throughput",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "rate(kafka_messages_consumed_total[1m])",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msg/s"
        }
      }
    },
    {
      "title": "Panel 3: API p99 Latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(api_request_latency_seconds_bucket[5m]))",
          "legendFormat": "p99 {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(api_request_latency_seconds_bucket[5m]))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 1.0}
            ]
          }
        }
      }
    },
    {
      "title": "Panel 4: A/B Test Conversion Rate",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "ab_test_conversion_rate",
          "legendFormat": "Variant {{variant}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 0.02},
              {"color": "green", "value": 0.04}
            ]
          }
        }
      }
    },
    {
      "title": "Panel 5: Recommendation Coverage %",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "recommendation_coverage_pct",
          "legendFormat": "Coverage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 30},
              {"color": "green", "value": 60}
            ]
          }
        }
      }
    },
    {
      "title": "Event Totals by Topic",
      "type": "stat",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
      "targets": [
        {
          "expr": "kafka_messages_consumed_total",
          "legendFormat": "{{topic}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Price Adjustments",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
      "targets": [
        {
          "expr": "rate(price_adjustments_total[5m])",
          "legendFormat": "{{direction}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["ecommerce", "real-time"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "title": "E-Commerce Intelligence Platform",
  "uid": "ecommerce-main"
}
